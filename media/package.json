{
  "name": "@clipboard-health/core-utils",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "affected": "nx affected --configuration ci --parallel 8 --targets build,lint,test",
    "architecture:check": "depcruise packages/*/src",
    "cpd": "jscpd .",
    "docs": "rm -rf docs && typedoc",
    "embed": "node --import tsx packages/embedex/src/bin/cli.ts --sourcesGlob 'packages/*/examples/**/*.{md,ts}'",
    "embed:check": "node --run embed -- --check",
    "eval": "promptfoo eval --config evals/promptfooconfig.ts",
    "eval:skill": "tsx scripts/runSkillEval.mts",
    "eval:view": "promptfoo view --yes",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "hook:pre-commit": "lint-staged",
    "hook:pre-push": "node --run verify",
    "knip": "NX_DAEMON=false knip --no-config-hints",
    "lint": "oxlint",
    "markdown:lint": "markdownlint-cli2 \"**/*.md\"",
    "plugin:version:check": "node scripts/embedPluginVersion.mts --check",
    "postinstall": "node --run sync-ai-rules",
    "prepare": "husky",
    "sync-ai-rules": "node scripts/embedPluginVersion.mts && nx build ai-rules && node ./dist/packages/ai-rules/scripts/sync.js common --exclude common/featureFlags",
    "syncpack:lint": "syncpack lint",
    "verify": "node scripts/verifyAll.mts"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.210",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@nx/devkit": "22.7.6",
    "@nx/eslint": "22.7.6",
    "@nx/eslint-plugin": "22.7.6",
    "@nx/js": "22.7.6",
    "@nx/vitest": "22.7.6",
    "@nx/webpack": "22.7.6",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.13.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.0.0",
    "eslint": "8.57.1",
    "eslint-plugin-promise": "7.3.0",
    "husky": "9.1.7",
    "jscpd": "5.0.12",
    "jsonc-eslint-parser": "3.1.0",
    "knip": "6.23.0",
    "lint-staged": "17.0.8",
    "markdownlint-cli2": "0.23.0",
    "nx": "22.7.6",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "promptfoo": "0.121.18",
    "syncpack": "15.3.2",
    "ts-node": "11.0.0-beta.1",
    "tsx": "4.23.0",
    "typedoc": "0.28.20",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk": {
      "zod": "3.25.76"
    },
    "@swc/core": "$@swc/core",
    "ts-node": "11.0.0-beta.1",
    "tsconfig-paths": "4.2.0"
  },
  "engines": {
    "node": "24.15.0",
    "npm": "~11.12.0"
  },
  "knip": {
    "ignoreBinaries": [
      "op"
    ]
  }
}
