{
  "extraKnownMarketplaces": {
    "clipboard": {
      "source": {
        "source": "github",
        "repo": "ClipboardHealth/core-utils"
      }
    },
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      }
    }
  },
  "enabledPlugins": {
    "core@clipboard": true,
    "nx@nx-claude-plugins": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/setup.sh"
          }
        ]
      }
    ]
  }
}
