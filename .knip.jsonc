{
  "$schema": "https://unpkg.com/knip@6/schema-jsonc.json",
  "ignore": [
    "**/webpack.*.js",
    "packages/ai-rules/scripts/*.ts",
    "packages/eslint-config/src/react.js",
    "packages/mongo-jobs/test/support/emulateCompletionOfBackgroundJobs.ts",
  ],
  "ignoreDependencies": [
    "@anthropic-ai/claude-agent-sdk",
    "@nx/webpack",
    "eslint-plugin-promise",
    "oxlint-tsgolint",
    "ts-node",
    "tslib",
    "webpack-cli",
  ],
  "webpack": false,
  "workspaces": {
    ".": {
      "entry": ["scripts/prepareTsgoPackage.mts"],
      "project": ["scripts/**/*.mts"],
    },
    "packages/analytics": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/clearance": {
      "entry": ["src/cli.ts", "src/ensureCli.ts"],
    },
    "packages/config": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/contract-core": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/embedex": {
      "entry": ["src/bin/**/*.ts", "src/index.ts"],
    },
    "packages/example-nestjs": {
      "entry": ["examples/**/*.ts", "src/main.ts"],
    },
    "packages/execution-context": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/groundcrew": {
      "entry": ["src/main.ts", "configExample.ts"],
    },
    "packages/json-api": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/mongo-jobs": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/notifications": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/rules-engine": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/testing-core": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/util-ts": {
      "entry": ["examples/**/*.ts", "src/index.ts"],
    },
    "packages/playwright-reporter-llm": {
      "entry": ["src/index.ts", "test/e2e/playwright.config.ts"],
    },
  },
}
