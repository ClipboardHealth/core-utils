{
  "threshold": 0,
  "minTokens": 90,
  "exitCode": 1,
  "reporters": ["console"],
  "pattern": "**/*.{js,cjs,mjs,ts,mts,tsx}",
  "ignore": [
    ".agents/**",
    ".claude/**",
    ".nx/**",
    ".rules/**",
    "coverage/**",
    "dist/**",
    "gen/**",
    "node_modules/**",
    "out-tsc/**",
    "test-results/**",
    "tmp/**",
    "evals/**",
    "packages/example-nestjs/**",
    "package-lock.json",
    "**/*.md",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/docs/**",
    "**/examples/**",
    "**/fixtures/**",
    "**/package.json",
    "**/project.json",
    "**/test/**",
    "**/tests/**",
    "**/tsconfig*.json",
    "**/__fixtures__/**",
    "**/vitest.config.ts",
    "**/vitest.config.mts",
    "**/bin/runCli.js"
  ],
  "absolute": false,
  "gitignore": true
}
