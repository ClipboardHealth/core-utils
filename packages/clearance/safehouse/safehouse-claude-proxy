#!/usr/bin/env bash
set -euo pipefail

source_path="${BASH_SOURCE[0]}"
while [ -h "$source_path" ]; do
  source_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
  link_target="$(readlink "$source_path")"
  case "$link_target" in
    /*) source_path="$link_target" ;;
    *) source_path="$source_dir/$link_target" ;;
  esac
done

script_dir="$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"

shim_dir="$(mktemp -d "${TMPDIR:-/tmp}/safehouse-claude-proxy-XXXXXX")"
cleanup() {
  rm -rf "$shim_dir"
}
trap cleanup EXIT

shim="$shim_dir/claude"
ln -s /bin/sh "$shim"

safehouse_args=()
agent_prelude=""

cmux_env_pass_names=(
  CMUX_BUNDLED_CLI_PATH
  CMUX_CLAUDE_HOOKS_DISABLED
  CMUX_CLAUDE_WRAPPER_SHIM
  CMUX_CLAUDE_WRAPPER_SHIM_ROOT
  CMUX_CUSTOM_CLAUDE_PATH
  CMUX_PANEL_ID
  CMUX_PRESERVE_CLAUDE_AUTH_SELECTION_ENV
  CMUX_PRESERVE_CLAUDE_AUTH_SELECTION_ENV_KEYS
  CMUX_SOCKET_PATH
  CMUX_SUPPRESS_SUBAGENT_NOTIFICATIONS
  CMUX_SURFACE_ID
  CMUX_TAB_ID
  CMUX_WORKSPACE_ID
)
cmux_wrapper_local_env_names=(
  CMUX_AGENT_LAUNCH_ARGV_B64
  CMUX_AGENT_LAUNCH_CWD
  CMUX_AGENT_LAUNCH_EXECUTABLE
  CMUX_AGENT_LAUNCH_KIND
  CMUX_CLAUDE_HOOK_CMUX_BIN
  CMUX_CLAUDE_PID
  CMUX_ORIGINAL_NODE_OPTIONS
  CMUX_ORIGINAL_NODE_OPTIONS_PRESENT
)

contains_name() {
  local needle="$1"
  shift
  local candidate
  for candidate in "$@"; do
    [ "$candidate" = "$needle" ] && return 0
  done
  return 1
}

warn_on_cmux_env_allowlist_drift() {
  local cmux_wrapper_path="/Applications/cmux.app/Contents/Resources/bin/cmux-claude-wrapper"
  local bundled_wrapper_path
  if [ -n "${CMUX_BUNDLED_CLI_PATH:-}" ]; then
    bundled_wrapper_path="$(dirname "$CMUX_BUNDLED_CLI_PATH")/cmux-claude-wrapper"
    if [ -r "$bundled_wrapper_path" ]; then
      cmux_wrapper_path="$bundled_wrapper_path"
    fi
  fi
  [ -r "$cmux_wrapper_path" ] || return 0

  local missing_names=""
  local referenced_name
  while IFS= read -r referenced_name; do
    contains_name "$referenced_name" "${cmux_env_pass_names[@]}" && continue
    contains_name "$referenced_name" "${cmux_wrapper_local_env_names[@]}" && continue
    missing_names="${missing_names}${missing_names:+, }$referenced_name"
  done < <(grep -Eoh 'CMUX_[A-Za-z0-9_]+' "$cmux_wrapper_path" | sort -u)

  if [ -n "$missing_names" ]; then
    printf 'safehouse-claude-proxy: cmux wrapper references unreviewed env vars: %s\n' "$missing_names" >&2
    printf 'safehouse-claude-proxy: update cmux_env_pass_names or cmux_wrapper_local_env_names after reviewing them.\n' >&2
  fi
}

if [ -n "${CMUX_SURFACE_ID:-}" ] || [ -n "${CMUX_CLAUDE_WRAPPER_SHIM:-}" ]; then
  warn_on_cmux_env_allowlist_drift
  cmux_env_pass_csv="$(IFS=,; printf '%s' "${cmux_env_pass_names[*]}")"

  cmux_read_dirs="/Applications/cmux.app"
  if [ -n "${XDG_STATE_HOME:-}" ]; then
    cmux_read_dirs="$cmux_read_dirs:$XDG_STATE_HOME/cmux"
  elif [ -n "${HOME:-}" ]; then
    cmux_read_dirs="$cmux_read_dirs:$HOME/.local/state/cmux"
  fi
  if [ -n "${CMUX_SOCKET_PATH:-}" ]; then
    cmux_socket_dir="$(dirname "$CMUX_SOCKET_PATH")"
    case ":$cmux_read_dirs:" in
      *":$cmux_socket_dir:"*) ;;
      *) cmux_read_dirs="$cmux_read_dirs:$cmux_socket_dir" ;;
    esac
  fi

  safehouse_args+=(
    "--add-dirs-ro=$cmux_read_dirs"
    "--env-pass=$cmux_env_pass_csv"
  )
  agent_prelude='if { [ -n "${CMUX_SURFACE_ID:-}" ] || [ -n "${CMUX_CLAUDE_WRAPPER_SHIM:-}" ]; } && [ -z "${CMUX_CUSTOM_CLAUDE_PATH:-}" ]; then _clearance_cmux_path=; _clearance_cmux_remaining_path=$PATH:; while [ -n "$_clearance_cmux_remaining_path" ]; do _clearance_cmux_path_entry=${_clearance_cmux_remaining_path%%:*}; _clearance_cmux_remaining_path=${_clearance_cmux_remaining_path#*:}; case "$_clearance_cmux_path_entry" in */cmux-cli-shims/*|*/cmux-cli-shims) ;; *) _clearance_cmux_path="${_clearance_cmux_path:+$_clearance_cmux_path:}$_clearance_cmux_path_entry" ;; esac; done; if _clearance_cmux_real_claude=$(PATH="$_clearance_cmux_path" command -v claude 2>/dev/null); then case "$_clearance_cmux_real_claude" in */cmux-cli-shims/*|*/cmux-cli-shims/claude) ;; *) export CMUX_CUSTOM_CLAUDE_PATH="$_clearance_cmux_real_claude" ;; esac; fi; unset _clearance_cmux_path _clearance_cmux_remaining_path _clearance_cmux_path_entry _clearance_cmux_real_claude; fi; '
fi

if [ "${#safehouse_args[@]}" -eq 0 ]; then
  "$script_dir/safehouse-clearance" \
    "$shim" -c "${agent_prelude}exec claude --permission-mode auto \"\$@\"" sh "$@"
else
  "$script_dir/safehouse-clearance" \
    "${safehouse_args[@]}" \
    "$shim" -c "${agent_prelude}exec claude --permission-mode auto \"\$@\"" sh "$@"
fi
