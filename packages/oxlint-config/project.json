{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "oxlint-config",
  "projectType": "library",
  "sourceRoot": "packages/oxlint-config/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "assets": [
          "packages/oxlint-config/*.md",
          "packages/oxlint-config/src/base.json",
          "packages/oxlint-config/src/vitest.json"
        ],
        "main": "packages/oxlint-config/src/index.js",
        "outputPath": "dist/packages/oxlint-config",
        "tsConfig": "packages/oxlint-config/tsconfig.lib.json"
      },
      "outputs": ["{options.outputPath}"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/oxlint-config/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/oxlint-config/vitest.config.ts"
      }
    }
  }
}
