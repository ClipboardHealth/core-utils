{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "oxlint-config",
  "projectType": "library",
  "sourceRoot": "packages/oxlint-config/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": ["packageBuild", "^production"],
      "outputs": ["{workspaceRoot}/dist/packages/oxlint-config"],
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/oxlint-config && tsgo --build packages/oxlint-config/tsconfig.lib.json && env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/oxlint-config --no-clean",
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/oxlint-config/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/oxlint-config/vitest.config.ts"
      }
    }
  }
}
