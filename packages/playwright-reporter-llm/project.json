{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "playwright-reporter-llm",
  "projectType": "library",
  "sourceRoot": "packages/playwright-reporter-llm/src",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["prepare-build-package", "^build"],
      "inputs": ["production", "^production", "{projectRoot}/*.md"],
      "outputs": ["{workspaceRoot}/dist/packages/playwright-reporter-llm"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/playwright-reporter-llm/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/playwright-reporter-llm/vitest.config.ts"
      }
    },
    "prepare-build-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/playwright-reporter-llm"
      }
    }
  }
}
