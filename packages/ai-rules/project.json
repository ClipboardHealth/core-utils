{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ai-rules",
  "projectType": "library",
  "sourceRoot": "packages/ai-rules/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "assets": [
          "packages/ai-rules/*.md",
          "packages/ai-rules/.ruler/**/*.md",
          "packages/ai-rules/.ruler/ruler.toml"
        ],
        "main": "packages/ai-rules/src/index.ts",
        "outputPath": "dist/packages/ai-rules",
        "tsConfig": "packages/ai-rules/tsconfig.lib.json"
      },
      "outputs": ["{options.outputPath}"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/ai-rules/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "lint:md": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint:md --workspace=@clipboard-health/ai-rules"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "packages/ai-rules/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
