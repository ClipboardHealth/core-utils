{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ai-rules",
  "projectType": "library",
  "sourceRoot": "packages/ai-rules/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsc -p packages/ai-rules/tsconfig.lib.json",
        "cwd": "."
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/ai-rules/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "lint:md": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run lint:md --workspace=@clipboard-health/ai-rules"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "packages/ai-rules/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
