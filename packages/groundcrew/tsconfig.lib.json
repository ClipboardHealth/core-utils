{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "NodeNext",
    "allowImportingTsExtensions": true,
    "moduleResolution": "NodeNext",
    "rewriteRelativeImportExtensions": true,
    "outDir": "../../dist/packages/groundcrew",
    "rootDir": ".",
    "types": ["node"],
    "tsBuildInfoFile": "../../.nx/tsbuildinfo/packages/groundcrew/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": ["vitest.config.ts", "src/testHelpers/**/*.ts", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../clearance/tsconfig.lib.json"
    }
  ]
}
