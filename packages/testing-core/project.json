{
  "name": "testing-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/testing-core/src",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["prepare-build-package", "^build"],
      "inputs": ["production", "^production", "{projectRoot}/*.md"],
      "outputs": ["{workspaceRoot}/dist/packages/testing-core"]
    },
    "prepare-build-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/testing-core"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/testing-core/**/*.[jt]s"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/testing-core/vitest.config.ts"
      }
    }
  }
}
