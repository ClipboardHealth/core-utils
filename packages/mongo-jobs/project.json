{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "mongo-jobs",
  "projectType": "library",
  "sourceRoot": "packages/mongo-jobs/src",
  "tags": ["scope:util"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["prepare-build-package", "^build"],
      "inputs": ["production", "^production", "{projectRoot}/*.md"],
      "outputs": ["{workspaceRoot}/dist/packages/mongo-jobs"],
      "options": {
        "command": "tsgo --build tsconfig.lib.json",
        "cwd": "packages/mongo-jobs"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/mongo-jobs/**/*.[jt]s?(x)"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/mongo-jobs/vitest.config.ts"
      }
    },
    "prepare-build-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/mongo-jobs"
      }
    }
  }
}
