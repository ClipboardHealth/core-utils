{
  "name": "contract-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/contract-core/src",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["prepare-build-package", "^build"],
      "inputs": ["packageBuild", "^production"],
      "outputs": ["{workspaceRoot}/dist/packages/contract-core"],
      "options": {
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["packages/contract-core/**/*.[jt]s"],
        "maxWarnings": 0
      },
      "outputs": ["{options.outputFile}"]
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/contract-core/vitest.config.ts"
      }
    },
    "prepare-build-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/contract-core"
      }
    }
  }
}
