{
  "name": "@clipboard-health/contract-core",
  "version": "4.1.0",
  "description": "Shared Zod schemas for Clipboard's contracts.",
  "keywords": [
    "contract",
    "schema",
    "typescript",
    "zod"
  ],
  "bugs": "https://github.com/ClipboardHealth/core-utils/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ClipboardHealth/core-utils.git",
    "directory": "packages/contract-core"
  },
  "type": "commonjs",
  "sideEffects": false,
  "main": "./src/index.js",
  "typings": "./src/index.d.ts",
  "publishConfig": {
    "exports": {
      "./package.json": "./package.json",
      ".": {
        "types": "./src/index.d.ts",
        "import": "./esm/src/index.js",
        "require": "./src/index.js",
        "default": "./src/index.js"
      },
      "./*": {
        "types": "./src/lib/schemas/*.d.ts",
        "import": "./esm/src/lib/schemas/*.js",
        "require": "./src/lib/schemas/*.js",
        "default": "./src/lib/schemas/*.js"
      }
    },
    "access": "public"
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@clipboard-health/testing-core": "2.8.0",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "zod": "^3"
  }
}
