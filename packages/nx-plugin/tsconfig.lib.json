{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "types": ["node"],
    "composite": true,
    "moduleResolution": "bundler",
    "outDir": "../../dist/packages/nx-plugin",
    "rootDir": ".",
    "tsBuildInfoFile": "../../.nx/tsbuildinfo/packages/nx-plugin/tsconfig.lib.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "src/generators/node-lib/files/src/lib/delete-me.ts__template__",
    "src/generators/node-lib/files/src/lib/delete-me.test.ts__template__",
    "src/generators/node-lib/files/src/index.ts__template__"
  ],
  "exclude": ["vitest.config.ts", "src/**/*.test.ts"]
}
