{
  "name": "nx-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/nx-plugin/src",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": ["prepare-build-package", "^build"],
      "inputs": ["packageBuild", "^production"],
      "outputs": ["{workspaceRoot}/dist/packages/nx-plugin"],
      "options": {
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "maxWarnings": 0
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "packages/nx-plugin/vitest.config.ts"
      },
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"]
    },
    "prepare-build-package": {
      "executor": "nx:run-commands",
      "options": {
        "command": "env -u NO_COLOR tsx scripts/prepareTsgoPackage.mts packages/nx-plugin"
      }
    }
  }
}
